# ================================================
# Telegram AI Assistant - Environment Variables
# ================================================

# --- Telegram ---
TELEGRAM_BOT_TOKEN=your-bot-token-from-botfather

# --- AI Model ---
# At least one of OPENAI_API_KEY or ANTHROPIC_API_KEY is required
OPENAI_API_KEY=sk-your-openai-key
# ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEFAULT_MODEL=gpt-4o

# --- Memory (mem0) ---
MEM0_API_KEY=m0-your-mem0-key
MEMORY_ENABLED=true

# --- MCP (Model Context Protocol) ---
# GitHub integration (requires personal access token)
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_your_github_token
# Notion integration (requires API token)
# NOTION_API_TOKEN=secret_your_notion_token

# --- RAG (Retrieval Augmented Generation) ---
RAG_ENABLED=true
# RAG_EMBEDDING_MODEL=text-embedding-3-small
# RAG_VECTOR_DB_PATH=./data/chroma
# RAG_MAX_RESULTS=10
# RAG_MIN_SIMILARITY=0.5

# --- Security ---
# DM_POLICY=open         # open, pairing, or allowlist
# ALLOWED_USERS=*        # Comma-separated Telegram user IDs, or * for all
# TELEGRAM_ALLOWED_USERS=*

# --- Features ---
# ENABLE_THREAD_SUMMARY=true
# ENABLE_TASK_SCHEDULER=true
# ENABLE_REACTIONS=true
# ENABLE_TYPING_INDICATOR=true

# --- Application ---
# LOG_LEVEL=info
# DATABASE_PATH=./data/assistant.db
